# EditorConfig - 统一代码风格
# https://editorconfig.org

root = true

# 所有文件的默认配置
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Python 文件
[*.py]
indent_size = 4
max_line_length = 127

# JavaScript/TypeScript 文件
[*.{js,jsx,ts,tsx,vue}]
indent_size = 2

# JSON/YAML 配置文件
[*.{json,yml,yaml}]
indent_size = 2

# Markdown 文件
[*.md]
trim_trailing_whitespace = false

# Makefile
[Makefile]
indent_style = tab
