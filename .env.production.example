# ============ Runtime profile ============
ENVIRONMENT=production
STRICT_PRODUCTION_MODE=true
PUBLIC_DEMO_MODE=false
APP_VERSION=1.0.0

# ============ API ============
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=false
CORS_ORIGINS=https://your-frontend-domain.example.com

# ============ JWT ============
SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============ MongoDB ============
MONGODB_URL=mongodb://admin:change-me@mongo:27017
MONGODB_DATABASE=ai_assistant_db
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_IDLE_TIME=60000
MONGODB_SERVER_SELECTION_TIMEOUT=30000
MONGODB_REQUIRED=true
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me

# ============ Session backend ============
SESSION_BACKEND=redis
REDIS_URL=redis://redis:6379/0
REDIS_SESSION_TTL=86400
REDIS_REQUIRED=true

# ============ LLM ============
LLM_API_KEY=replace-with-your-production-llm-api-key
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_REQUIRED=false

# ============ Retrieval ============
USE_CHROMADB=false
USE_HYBRID_SEARCH=false
KNOWLEDGE_BASE_REQUIRED=true
VECTOR_SEARCH_WEIGHT=0.7
KEYWORD_SEARCH_WEIGHT=0.3

# ============ Frontend ============
VITE_API_BASE_URL=https://your-api-domain.example.com
