# ============ Runtime profile ============
ENVIRONMENT=production
STRICT_PRODUCTION_MODE=true
PUBLIC_DEMO_MODE=false
ADMIN_USERNAMES=
APP_VERSION=1.0.0

# ============ API ============
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=false
CORS_ORIGINS=https://rag.gyfbest.cn,https://api-rag.gyfbest.cn,http://rag.gyfbest.cn,http://rag.gyfbest.cn:18080,http://146.56.208.45:18080
CHAT_RATE_LIMIT=60/minute
CHAT_STREAM_RATE_LIMIT=60/minute
CHAT_PERSPECTIVES_RATE_LIMIT=30/minute
CHAT_INTERACTIVE_RATE_LIMIT=30/minute
CHAT_LEARNING_EVENT_TIMEOUT_SECONDS=0.5
DB_HEALTH_CHECK_TIMEOUT_SECONDS=0.75

# ============ Public entry ============
# Caddy terminates public 80/443 for rag.gyfbest.cn.
# The frontend also stays publicly reachable on 18080 for direct IP:port demos.
BACKEND_BIND=127.0.0.1
BACKEND_PORT=8001
FRONTEND_BIND=0.0.0.0
FRONTEND_PORT=18080
CADDY_DOMAIN=rag.gyfbest.cn
CADDY_HTTP_BIND=0.0.0.0
CADDY_HTTP_PORT=80
CADDY_HTTPS_BIND=0.0.0.0
CADDY_HTTPS_PORT=443

# ============ JWT ============
SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============ MongoDB ============
MONGODB_URL=mongodb://admin:change-me@mongo:27017
MONGODB_DATABASE=ai_assistant_db
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_IDLE_TIME=60000
MONGODB_SERVER_SELECTION_TIMEOUT=30000
MONGODB_REQUIRED=true
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me

# ============ Session backend ============
SESSION_BACKEND=redis
REDIS_URL=redis://redis:6379/0
REDIS_SESSION_TTL=86400
REDIS_REQUIRED=true

# ============ LLM ============
LLM_PROVIDER=api
LLM_API_KEY=replace-with-your-production-llm-api-key
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TIMEOUT=60
LLM_REQUIRED=false

# ============ Retrieval ============
USE_CHROMADB=false
USE_HYBRID_SEARCH=false
KNOWLEDGE_BASE_REQUIRED=true
GRAPH_RAG_ENABLED=true
VECTOR_SEARCH_WEIGHT=0.7
KEYWORD_SEARCH_WEIGHT=0.3

# ============ Observability ============
LOG_LEVEL=INFO
ENABLE_METRICS=true

# ============ Frontend ============
# Cloudflare Pages + remote backend:
# Set this to your public backend origin, for example https://api-rag.gyfbest.cn
# Same-origin VPS+Caddy deployments may keep this empty.
VITE_API_BASE_URL=https://api-rag.gyfbest.cn


