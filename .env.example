# ============ Runtime profile ============
ENVIRONMENT=development
STRICT_PRODUCTION_MODE=false
PUBLIC_DEMO_MODE=true
APP_VERSION=1.0.0

# ============ API ============
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============ JWT ============
SECRET_KEY=replace-with-a-strong-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============ MongoDB ============
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=ai_assistant_db
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_IDLE_TIME=60000
MONGODB_SERVER_SELECTION_TIMEOUT=30000
MONGODB_REQUIRED=false

# Docker Compose Mongo auth
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme

# ============ Session backend ============
SESSION_BACKEND=auto
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=86400
REDIS_REQUIRED=false

# ============ LLM (讯飞星火 Spark - OpenAI 兼容接口) ============
LLM_API_KEY=replace-with-your-spark-api-key
LLM_API_BASE_URL=https://spark-api-open.xf-yun.com/v1
LLM_MODEL=lite
LLM_REQUIRED=false

# ============ DeepScientist / Codex ============
OPENAI_API_KEY=replace-with-your-openai-api-key
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token

# ============ Retrieval ============
USE_CHROMADB=false
USE_HYBRID_SEARCH=false
KNOWLEDGE_BASE_REQUIRED=false
VECTOR_SEARCH_WEIGHT=0.7
KEYWORD_SEARCH_WEIGHT=0.3

# ============ Frontend ============
VITE_API_BASE_URL=http://localhost:8001
